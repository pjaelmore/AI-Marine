{
  "version": 8,
  "name": "Marine (Dev)",
  "sources": {
    "osm": {
      "type": "raster",
      "tiles": [
        "https://tile.openstreetmap.org/{z}/{x}/{y}.png"
      ],
      "tileSize": 256,
      "minzoom": 0,
      "maxzoom": 19,
      "attribution": "© OpenStreetMap contributors"
    },
    "openseamap": {
      "type": "raster",
      "tiles": [
        "https://tiles.openseamap.org/seamark/{z}/{x}/{y}.png"
      ],
      "tileSize": 256,
      "minzoom": 0,
      "maxzoom": 18,
      "attribution": "© OpenSeaMap contributors"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#0F2A47"
      }
    },
    {
      "id": "osm-base",
      "type": "raster",
      "source": "osm"
    },
    {
      "id": "openseamap-overlay",
      "type": "raster",
      "source": "openseamap"
    }
  ]
}
